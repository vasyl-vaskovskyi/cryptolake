/.idea/cryptolake.iml
/.idea/misc.xml
/.idea/modules.xml
/.idea/vcs.xml
/.idea/workspace.xml
.DS_Store
.env
/data/
.worktrees/

# Gradle / Java build artifacts (formerly cryptolake-java/.gitignore).
.gradle/
build/
*.class
*.iml

# Local sentinel written by scripts/start-local.sh after the first-run
# backup-topic retention setup completes. Per-host state, never shared.
.cryptolake-backup-topics-configured

# PID file for the macOS `caffeinate` watchdog start-local.sh launches to
# keep the system idle-sleep-disabled while the stack runs. Per-host
# transient state.
.cryptolake-caffeinate.pid

# Ignore most of .claude/ (local settings, worktree metadata) but track the
# shared skill bundle and slash commands that are part of the repo.
.claude/*
!.claude/skills/
!.claude/commands/
/.idea/gradle.xml
