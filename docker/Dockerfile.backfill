# docker/Dockerfile.backfill
# syntax=docker/dockerfile:1.7

FROM eclipse-temurin:21-jdk AS build
WORKDIR /src
COPY . /src/
RUN ./gradlew :backfill:installDist --no-daemon

FROM eclipse-temurin:21-jre
ENV JAVA_OPTS="-XX:+UseZGC -XX:+ZGenerational"
WORKDIR /app
COPY --from=build /src/backfill/build/install/backfill /app/
ENTRYPOINT ["/app/bin/backfill"]
