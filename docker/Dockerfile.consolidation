# docker/Dockerfile.consolidation
# syntax=docker/dockerfile:1.7

FROM eclipse-temurin:21-jdk AS build
WORKDIR /src
COPY . /src/
RUN ./gradlew :consolidation:installDist --no-daemon

FROM eclipse-temurin:21-jre
ENV JAVA_OPTS="-XX:+UseZGC -XX:+ZGenerational"
WORKDIR /app
COPY --from=build /src/consolidation/build/install/consolidation /app/
ENTRYPOINT ["/app/bin/consolidation"]
